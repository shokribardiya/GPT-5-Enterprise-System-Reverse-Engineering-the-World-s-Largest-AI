class Tensor:
    """Multi-dimensional tensor with comprehensive operations."""
    
    def __init__(self, data, shape=None, dtype=float):
        self.dtype = dtype
        if isinstance(data, (int, float)):
            self.data = dtype(data)
            self.shape = tuple(shape) if shape else ()
        elif isinstance(data, list):
            self.data = data
            if shape is None:
                self.shape = self._infer_shape(data)
            else:
                self.shape = tuple(shape)
        else:
            raise TypeError(f"Unsupported data type: {type(data)}")
    
    @staticmethod
    def _infer_shape(nested):
        if not isinstance(nested, list):
            return ()
        if not nested:
            return (0,)
        return (len(nested),) + Tensor._infer_shape(nested[0])
    
    @staticmethod
    def zeros(*shape):
        if len(shape) == 0:
            return Tensor(0.0, ())
        if len(shape) == 1:
            return Tensor([0.0] * shape[0], shape)
        return Tensor([Tensor.zeros(*shape[1:]).data for _ in range(shape[0])], shape)
    
    @staticmethod
    def ones(*shape):
        if len(shape) == 0:
            return Tensor(1.0, ())
        if len(shape) == 1:
            return Tensor([1.0] * shape[0], shape)
        return Tensor([Tensor.ones(*shape[1:]).data for _ in range(shape[0])], shape)
    
    @staticmethod
    def randn(*shape):
        if len(shape) == 0:
            return Tensor(random.gauss(0, 1), ())
        if len(shape) == 1:
            return Tensor([random.gauss(0, 1) for _ in range(shape[0])], shape)
        return Tensor([Tensor.randn(*shape[1:]).data for _ in range(shape[0])], shape)
    
    @staticmethod
    def glorot(*shape):
        """Xavier/Glorot initialization."""
        if len(shape) < 2:
            return Tensor.randn(*shape)
        fan_in = shape[-1]
        fan_out = shape[-2] if len(shape) >= 2 else 1
        scale = math.sqrt(6.0 / (fan_in + fan_out))
        if len(shape) == 2:
            return Tensor([[random.uniform(-scale, scale) for _ in range(shape[1])] 
                          for _ in range(shape[0])], shape)
        return Tensor.randn(*shape)
    
    def to_list(self):
        """Convert tensor to nested list."""
        return self.data
    
    def __repr__(self):
        return f"Tensor(shape={self.shape}, dtype={self.dtype})"

