# MODULE 4: ROTARY POSITION EMBEDDINGS (RoPE)
# ═══════════════════════════════════════════════════════════════════════════════

class RotaryPositionEmbedding:
    """
    Rotary Position Embeddings with NTK-aware scaling.
    
    GPT-5 uses RoPE to encode positional information directly into the
    attention mechanism. The base frequency theta is set to 10,000,000
    (NTK-aware) to enable extrapolation to 400K+ token contexts.
    
    RoPE applies rotation matrices to query and key vectors:
        RoPE(x, pos) = R(pos) @ x
    where R(pos) is a block-diagonal rotation matrix.
    """
    
    def __init__(self, dim: int, max_position: int = 409600, theta: float = 10000000.0):
        self.dim = dim
        self.max_position = max_position
        self.theta = theta
        # Precompute inverse frequencies
        self.inv_freqs = [1.0 / (theta ** (2 * i / dim)) for i in range(0, dim, 2)]
        # Precompute cos/sin cache for efficiency
        self._cos_cache: Dict[int, List[float]] = {}
        self._sin_cache: Dict[int, List[float]] = {}
    
    def _compute_for_position(self, position: int) -> Tuple[List[float], List[float]]:
        """Compute cos and sin values for a given position."""
        if position in self._cos_cache:
            return self._cos_cache[position], self._sin_cache[position]
        
        cos_vals = []
        sin_vals = []
        for freq in self.inv_freqs:
            angle = position * freq
            cos_vals.append(math.cos(angle))
            sin_vals.append(math.sin(angle))
        
        # Cache the result (limit cache size)
        if len(self._cos_cache) > 100000:
            self._cos_cache.clear()
            self._sin_cache.clear()
        self._cos_cache[position] = cos_vals
        self._sin_cache[position] = sin_vals
        
        return cos_vals, sin_vals
    
    def apply_rotary(self, x: List[float], position: int) -> List[float]:
        """
        Apply rotary position embedding to a vector.
        
        For each consecutive pair (x[2i], x[2i+1]):
            x'[2i]   = x[2i] * cos(θ_i) - x[2i+1] * sin(θ_i)
            x'[2i+1] = x[2i] * sin(θ_i) + x[2i+1] * cos(θ_i)
        """
        cos_vals, sin_vals = self._compute_for_position(position)
        result = x[:]
        for i in range(0, min(len(x), len(cos_vals) * 2), 2):
            if i + 1 >= len(x):
                break
            freq_idx = i // 2
            if freq_idx >= len(cos_vals):
                break
            cos_a = cos_vals[freq_idx]
            sin_a = sin_vals[freq_idx]
            x0, x1 = result[i], result[i + 1]
            result[i] = x0 * cos_a - x1 * sin_a
            result[i + 1] = x0 * sin_a + x1 * cos_a
        return result
    
    def apply_to_heads(self, heads: List[List[float]], position: int) -> List[List[float]]:
        """Apply RoPE to a list of attention head vectors."""
        return [self.apply_rotary(h, position) for h in heads]

