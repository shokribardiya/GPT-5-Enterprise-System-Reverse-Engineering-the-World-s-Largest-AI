class GroupedQueryAttention:
    """
    Grouped Query Attention with Sliding Window and Attention Sinks.
    
    GPT-5 uses GQA to reduce KV cache memory while maintaining quality.
    With 128 query heads and 16 KV heads (8:1 ratio), KV cache memory
    is reduced by 8x compared to standard multi-head attention.
    
    Features:
    - Grouped Query Attention: Multiple Q heads share each KV head
    - Rotary Position Embeddings: Applied to Q and K before attention
    - Sliding Window: Each token attends to at most W previous tokens
    - Attention Sinks: First few tokens serve as stable attention anchors
    - KV Caching: Efficient autoregressive generation
    """
    
    def __init__(self, config: GPT5Config, layer_idx: int):
        self.config = config
        self.layer_idx = layer_idx
        self.hidden_size = config.hidden_size
        self.num_heads = config.num_attention_heads
        self.num_kv_heads = config.num_kv_heads
        self.head_dim = config.head_dim
        self.kv_head_dim = config.kv_head_dim
        self.heads_per_kv = self.num_heads // self.num_kv_heads
        self.sliding_window = config.sliding_window
        self.use_sink = config.use_attention_sink
        self.num_sinks = config.num_attention_sinks
        
        # RoPE for positional encoding
        self.rope = RotaryPositionEmbedding(
            self.head_dim, config.max_position_embeddings, config.rope_theta
        )
        
        # Initialize projection matrices
        scale = math.sqrt(2.0 / (3 * self.hidden_size))
        cm = CoreMath
        
        # Q: hidden_size → num_heads × head_dim
        self.W_q = cm.random_matrix(self.hidden_size, self.num_heads * self.head_dim, scale)
        # K: hidden_size → num_kv_heads × kv_head_dim
        self.W_k = cm.random_matrix(self.hidden_size, self.num_kv_heads * self.kv_head_dim, scale)
        # V: hidden_size → num_kv_heads × kv_head_dim
        self.W_v = cm.random_matrix(self.hidden_size, self.num_kv_heads * self.kv_head_dim, scale)
        # Output: num_heads × head_dim → hidden_size
        self.W_o = cm.random_matrix(self.num_heads * self.head_dim, self.hidden_size, scale)
    
    def _project(self, x: List[float]):
        """Project input to Q, K, V."""
        cm = CoreMath
        
        # Q projection
        q_flat = cm.matvec_mul(self.W_q, x)
        queries = []
        for h in range(self.num_heads):
            start = h * self.head_dim
            queries.append(q_flat[start:start + self.head_dim])
        
        # K projection
        k_flat = cm.matvec_mul(self.W_k, x)
        keys = []
        for h in range(self.num_kv_heads):
            start = h * self.kv_head_dim
            keys.append(k_flat[start:start + self.kv_head_dim])
        
        # V projection
        v_flat = cm.matvec_mul(self.W_v, x)
        values = []
        for h in range(self.num_kv_heads):
            start = h * self.kv_head_dim
            values.append(v_flat[start:start + self.kv_head_dim])
        
        return queries, keys, values
    
    def forward(
        self, hidden_states: List[float], position: int = 0,
        kv_cache_keys: List[List[float]] = None,
        kv_cache_values: List[List[float]] = None,
        attention_mask: List[List[float]] = None
    ) -> Tuple[List[float], List[List[float]], List[List[float]]]:
        """
        Forward pass of GQA.
        
        Args:
            hidden_states: Input tensor [hidden_size]
            position: Current token position
            kv_cache_keys: Cached key tensors from previous steps
            kv_cache_values: Cached value tensors from previous steps
            attention_mask: Optional attention mask
        
        Returns:
            output: Attention output [hidden_size]
            new_keys: Updated key cache
            new_values: Updated value cache
        """
        cm = CoreMath
        
        # Project to Q, K, V
        queries, keys, values = self._project(hidden_states)
        
        # Apply RoPE to Q and K
        for h in range(self.num_heads):
            queries[h] = self.rope.apply_rotary(queries[h], position)
        for h in range(self.num_kv_heads):
            keys[h] = self.rope.apply_rotary(keys[h], position)
        
        # Expand KV for GQA: repeat each KV head for its query group
        expanded_keys = []
        expanded_values = []
        for h in range(self.num_heads):
            kv_idx = h // self.heads_per_kv
            expanded_keys.append(keys[kv_idx])
            expanded_values.append(values[kv_idx])
        
        # Manage KV cache
        if kv_cache_keys is not None and kv_cache_values is not None:
            all_keys = kv_cache_keys + expanded_keys
            all_values = kv_cache_values + expanded_values
        else:
            all_keys = expanded_keys
            all_values = expanded_values
        
        seq_len = len(all_keys[0]) if all_keys else 0  # This is wrong; fix
        seq_len = len(all_keys)  # Number of key vectors
        
        # Compute scaled dot-product attention
        scale = 1.0 / math.sqrt(self.head_dim)
        attn_outputs = []
        
        for h in range(self.num_heads):
            q_h = queries[h]
            
            # Compute attention scores
            scores = []
            for t in range(seq_len):
                k_h = all_keys[t]
                score = sum(q_h[d] * k_h[d] for d in range(self.head_dim)) * scale
                scores.append(score)
            
            # Apply sliding window and attention sinks
            if self.sliding_window > 0 and seq_len > self.sliding_window:
                window_start = max(0, seq_len - self.sliding_window)
                if self.use_sink:
                    # Keep attention sinks (first few tokens)
                    sink_indices = list(range(min(self.num_sinks, seq_len)))
                    window_indices = list(range(window_start, seq_len))
                    effective_indices = sink_indices + [i for i in window_indices if i not in sink_indices]
                else:
                    effective_indices = list(range(window_start, seq_len))
                
                filtered_scores = [scores[i] for i in effective_indices]
                attn_weights = cm.softmax(filtered_scores)
                
                output_h = [0.0] * self.head_dim
                for wi, t in enumerate(effective_indices):
                    v_h = all_values[t]
                    w = attn_weights[wi]
                    for d in range(self.head_dim):
                        output_h[d] += w * v_h[d]
            else:
                attn_weights = cm.softmax(scores)
                output_h = [0.0] * self.head_dim
                for t in range(seq_len):
                    v_h = all_values[t]
                    w = attn_weights[t]
                    for d in range(self.head_dim):
                        output_h[d] += w * v_h[d]
            
            attn_outputs.append(output_h)
        
        # Concatenate heads and project
        concat = []
        for h in range(self.num_heads):
            concat.extend(attn_outputs[h])
        output = cm.matvec_mul(self.W_o, concat)
        
        return output, keys, values

