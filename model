# MODULE 11: BYTE-PAIR ENCODING TOKENIZER
# ═══════════════════════════════════════════════════════════════════════════════

class BPETokenizer:
    """
    Byte-Pair Encoding Tokenizer for GPT-5.
    
    GPT-5 uses a BPE tokenizer with approximately 100K tokens.
    This implementation provides:
    - Subword tokenization with merges learned from training data
    - Special token handling (BOS, EOS, PAD, UNK)
    - Efficient encoding/decoding
    - Support for extended vocabulary
    
    The tokenizer splits text into subword units, balancing vocabulary size
    with coverage. Common words remain whole, rare words are split into
    reusable pieces, ensuring no input produces an "unknown token."
    """
    
    def __init__(self, vocab_size: int = 100288):
        self.vocab_size = vocab_size
        
        # Special tokens
        self.PAD_TOKEN = "<|pad|>"
        self.BOS_TOKEN = "<|begin_of_text|>"
        self.EOS_TOKEN = "<|end_of_text|>"
        self.UNK_TOKEN = "<|unk|>"
        self.SEP_TOKEN = "<|separator|>"
        self.IMG_TOKEN = "<|image|>"
        self.AUD_TOKEN = "<|audio|>"
        self.VID_TOKEN = "<|video|>"
        
        # Build vocabulary
        self.vocab: Dict[str, int] = {}
        self.inv_vocab: Dict[int, str] = {}
        self.merges: Dict[Tuple[str, str], str] = {}
        
        # Initialize with byte-level tokens (0-255)
        for i in range(256):
            token = chr(i)
            self.vocab[token] = i
            self.inv_vocab[i] = token
        
        # Add common characters
        common_chars = (
            " abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
            "0123456789.,!?;:'\"()[]{}<>/\\|@#$%^&*_+-=~`\n\t\r"
        )
        for ch in common_chars:
            if ch not in self.vocab:
                idx = len(self.vocab)
                self.vocab[ch] = idx
                self.inv_vocab[idx] = ch
        
        # Add common subword tokens
        common_subwords = [
            "the", "ing", "tion", "ed", "er", "or", "ly", "es", "ment",
            "able", "re", "un", "pre", "pro", "con", "ex", "sub", "inter",
            "trans", "def", "class", "return", "import", "print", "function",
            "model", "data", "code", "system", "user", "query", "response",
            "text", "image", "audio", "video", "language", "learning",
            "neural", "network", "transformer", "attention", "layer",
            "token", "embedding", "generation", "training", "inference",
        ]
        for sw in common_subwords:
            if sw not in self.vocab:
                idx = len(self.vocab)
                self.vocab[sw] = idx
                self.inv_vocab[idx] = sw
        
        # Add special tokens
        for token in [self.PAD_TOKEN, self.BOS_TOKEN, self.EOS_TOKEN,
                      self.UNK_TOKEN, self.SEP_TOKEN, self.IMG_TOKEN,
                      self.AUD_TOKEN, self.VID_TOKEN]:
            if token not in self.vocab:
                idx = len(self.vocab)
                self.vocab[token] = idx
                self.inv_vocab[idx] = token
        
        self.pad_id = self.vocab.get(self.PAD_TOKEN, 0)
        self.bos_id = self.vocab.get(self.BOS_TOKEN, 0)
        self.eos_id = self.vocab.get(self.EOS_TOKEN, 0)
        self.unk_id = self.vocab.get(self.UNK_TOKEN, 0)
    
    def encode(self, text: str, add_special_tokens: bool = True) -> List[int]:
        """
        Encode text to token IDs.
        
        Uses greedy longest-match-first encoding with the vocabulary.
        For production GPT-5, this would use the learned BPE merge table.
        """
        if not text:
            return [self.bos_id, self.eos_id] if add_special_tokens else []
        
        tokens = []
        if add_special_tokens:
            tokens.append(self.bos_id)
        
        i = 0
        while i < len(text):
            # Try to match the longest possible token
            matched = False
            # Check multi-character tokens (up to 20 chars)
            for length in range(min(20, len(text) - i), 0, -1):
                sub = text[i:i + length]
                if sub in self.vocab:
                    tokens.append(self.vocab[sub])
                    i += length
                    matched = True
                    break
            
            if not matched:
                # Fallback: use character-level encoding
                ch = text[i]
                if ch in self.vocab:
                    tokens.append(self.vocab[ch])
                else:
                    # Byte fallback
                    for byte in ch.encode('utf-8', errors='replace'):
                        byte_token = chr(byte)
                        tokens.append(self.vocab.get(byte_token, self.unk_id))
                i += 1
        
        if add_special_tokens:
            tokens.append(self.eos_id)
        
        return tokens
    
    def decode(self, token_ids: List[int], skip_special_tokens: bool = True) -> str:
        """Decode token IDs back to text."""
        special_ids = {self.pad_id, self.bos_id, self.eos_id, self.unk_id}
        
        result = []
        for tid in token_ids:
            if skip_special_tokens and tid in special_ids:
                continue
            token = self.inv_vocab.get(tid, self.UNK_TOKEN)
            result.append(token)
        
        return ''.join(result)
    
    def encode_batch(self, texts: List[str], max_length: int = None) -> List[List[int]]:
        """Encode a batch of texts."""
        encoded = [self.encode(text) for text in texts]
        
        if max_length is not None:
            # Truncate or pad to max_length
            for i, tokens in enumerate(encoded):
                if len(tokens) > max_length:
                    encoded[i] = tokens[:max_length]
                else:
                    encoded[i] = tokens + [self.pad_id] * (max_length - len(tokens))
        
        return encoded
    
    def __len__(self) -> int:
        return len(self.vocab)

