# MODULE 8: HIERARCHICAL MIXTURE OF EXPERTS (HMoE)
# ═══════════════════════════════════════════════════════════════════════════════

class HierarchicalMoE:
    """
    Hierarchical Mixture of Experts (HMoE) — GPT-5's core innovation.
    
    Architecture (from leaked specifications and research):
    - 128 specialized expert FFN modules
    - 3-level hierarchical routing (Global → Domain → Local)
    - Sparse activation: only ~5% (top-6 of 128) experts per token
    - Each expert specializes in different knowledge domains
    - Load-balanced routing via auxiliary loss
    
    Level 1 (Global Router): Routes to 8 domain clusters
        - STEM, Code, Humanities, Conversation, Creative, Legal, Medical, General
    Level 2 (Domain Router): Routes to 16 sub-experts within cluster
    Level 3 (Local Optimizer): Fine-grained token-level weight adjustment
    
    The hierarchical design reduces routing complexity from O(N) to O(log N)
    while maintaining expert specialization quality.
    """
    
    def __init__(self, config: GPT5Config):
        self.config = config
        self.hidden_size = config.hidden_size
        self.num_experts = config.num_experts
        self.num_active = config.num_active_experts
        self.num_levels = config.num_hierarchical_levels
        self.aux_loss_coef = config.router_aux_loss_coef
        
        # Domain structure: 8 domains × 16 experts each = 128 experts
        self.num_domains = 8
        self.experts_per_domain = self.num_experts // self.num_domains
        
        cm = CoreMath
        scale = math.sqrt(2.0 / self.hidden_size)
        
        # Level 1: Global router → domain selection
        self.global_router_W = cm.random_matrix(self.hidden_size, self.num_domains, scale)
        
        # Level 2: Per-domain routers → expert selection
        self.domain_routers_W = []
        for d in range(self.num_domains):
            self.domain_routers_W.append(
                cm.random_matrix(self.hidden_size, self.experts_per_domain, scale)
            )
        
        # Expert networks (each is a SwiGLU FFN)
        self.experts = []
        for e in range(self.num_experts):
            self.experts.append(SwiGLUFFN(self.hidden_size, config.expert_ffn_size))
        
        # Load balancing counters (for auxiliary loss)
        self.expert_usage = [0.0] * self.num_experts
        self.total_tokens = 0
    
    def _route(self, x: List[float]) -> Tuple[List[int], List[float]]:
        """
        Three-level hierarchical routing.
        
        Returns:
            expert_indices: List of selected expert indices
            expert_weights: Normalized weights for each selected expert
        """
        cm = CoreMath
        
        # Level 1: Global routing — select top domains
        global_logits = cm.matvec_mul(self.global_router_W, x)
        global_probs = cm.softmax(global_logits)
        
        # Get top domains (select more than needed to ensure coverage)
        domain_scores = list(enumerate(global_probs))
        domain_scores.sort(key=lambda p: p[1], reverse=True)
        active_domains = domain_scores[:4]  # Top-4 domains
        
        # Level 2+3: Within-domain expert routing
        all_expert_scores = []
        for domain_idx, domain_weight in active_domains:
            domain_logits = cm.matvec_mul(self.domain_routers_W[domain_idx], x)
            domain_probs = cm.softmax(domain_logits)
            
            for local_idx, local_prob in enumerate(domain_probs):
                global_expert_idx = domain_idx * self.experts_per_domain + local_idx
                # Combined score: domain_weight × local_prob
                combined_score = domain_weight * local_prob
                all_expert_scores.append((global_expert_idx, combined_score))
        
        # Select top-k experts globally
        all_expert_scores.sort(key=lambda p: p[1], reverse=True)
        top_experts = all_expert_scores[:self.num_active]
        
        # Extract indices and re-normalize weights
        expert_indices = [e for e, _ in top_experts]
        raw_weights = [w for _, w in top_experts]
        total_weight = sum(raw_weights)
        
        if total_weight > 0:
            expert_weights = [w / total_weight for w in raw_weights]
        else:
            expert_weights = [1.0 / len(top_experts)] * len(top_experts)
        
        # Update usage statistics
        for e in expert_indices:
            self.expert_usage[e] += 1
        self.total_tokens += 1
        
        return expert_indices, expert_weights
    
    def forward(self, x: List[float]) -> List[float]:
        """
        Route token through selected experts and combine outputs.
        
        GPT-5 activates only ~5% of experts per token (6 out of 128),
        drastically reducing computational cost while maintaining quality
        through specialized expert knowledge.
        """
        expert_indices, expert_weights = self._route(x)
        
        # Compute weighted sum of expert outputs
        output = [0.0] * self.hidden_size
        for expert_idx, weight in zip(expert_indices, expert_weights):
            expert_out = self.experts[expert_idx].forward(x)
            for i in range(self.hidden_size):
                output[i] += weight * expert_out[i]
        
        return output
    
    def compute_auxiliary_loss(self) -> float:
        """
        Compute load-balancing auxiliary loss.
        
        Encourages uniform expert utilization to prevent expert collapse,
        where only a few experts are used for all tokens.
        """
        if self.total_tokens == 0:
            return 0.0
        
        n = self.num_experts
        # Fraction of tokens routed to each expert
        f_i = [usage / self.total_tokens for usage in self.expert_usage]
        # Mean usage
        mean_f = 1.0 / n
        # Variance penalty
        loss = n * sum(f * f for f in f_i) - 1.0
        
        return self.aux_loss_coef * loss

