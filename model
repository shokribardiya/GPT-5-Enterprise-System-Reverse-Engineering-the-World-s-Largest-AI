class RMSNorm:
    """
    Root Mean Square Layer Normalization.
    
    GPT-5 uses RMSNorm instead of LayerNorm for faster training and inference.
    RMSNorm(x) = x / RMS(x) * γ
    where RMS(x) = sqrt(E[x²] + ε)
    
    This is computationally cheaper than LayerNorm (no mean subtraction)
    while providing equivalent training stability.
    """
    
    def __init__(self, hidden_size: int, eps: float = 1e-6):
        self.weight = [1.0] * hidden_size  # Learnable scale γ
        self.eps = eps
    
    def forward(self, x: List[float]) -> List[float]:
        """Apply RMSNorm to input vector."""
        n = len(x)
        ms = sum(xi * xi for xi in x) / n
        rms = 1.0 / math.sqrt(ms + self.eps)
        return [xi * rms * self.weight[i] for i, xi in enumerate(x)]

