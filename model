# MODULE 9: TRANSFORMER BLOCK
# ═══════════════════════════════════════════════════════════════════════════════

class GPT5TransformerBlock:
    """
    Pre-Norm Transformer Block — the fundamental building block of GPT-5.
    
    Architecture:
        x = x + GQA(RMSNorm(x))      # Attention sub-layer with pre-norm
        x = x + HMoE(RMSNorm(x))     # MoE FFN sub-layer with pre-norm
    
    Each block contains:
    - RMS Normalization (×2): Pre-normalization for training stability
    - Grouped Query Attention: Multi-head attention with GQA
    - Hierarchical MoE: Sparse expert mixture for FFN
    - Residual Connections: Skip connections for gradient flow
    
    GPT-5 has 120 such blocks in the fast model and 240+ in the reasoning model.
    """
    
    def __init__(self, config: GPT5Config, layer_idx: int):
        self.config = config
        self.layer_idx = layer_idx
        
        # Attention
        self.attention = GroupedQueryAttention(config, layer_idx)
        
        # MoE FFN
        self.moe = HierarchicalMoE(config)
        
        # Pre-norm layers
        self.attn_norm = RMSNorm(config.hidden_size, config.rms_norm_eps)
        self.ffn_norm = RMSNorm(config.hidden_size, config.rms_norm_eps)
    
    def forward(
        self, hidden_states: List[float], position: int = 0,
        kv_cache_keys: List[List[float]] = None,
        kv_cache_values: List[List[float]] = None,
    ) -> Tuple[List[float], List[List[float]], List[List[float]]]:
        """
        Forward pass through one transformer block.
        
        Args:
            hidden_states: Input tensor [hidden_size]
            position: Current token position
            kv_cache_keys: Cached keys from previous forward passes
            kv_cache_values: Cached values from previous forward passes
        
        Returns:
            output: Transformed hidden states
            new_keys: Updated key cache
            new_values: Updated value cache
        """
        # Pre-norm for attention
        normed = self.attn_norm.forward(hidden_states)
        attn_out, new_keys, new_values = self.attention.forward(
            normed, position, kv_cache_keys, kv_cache_values
        )
        
        # Residual connection 1: x = x + Attention(Norm(x))
        hidden_states = [hidden_states[i] + attn_out[i] for i in range(len(hidden_states))]
        
        # Pre-norm for FFN (MoE)
        normed2 = self.ffn_norm.forward(hidden_states)
        ffn_out = self.moe.forward(normed2)
        
        # Residual connection 2: x = x + MoE(Norm(x))
        hidden_states = [hidden_states[i] + ffn_out[i] for i in range(len(hidden_states))]
        
        return hidden_states, new_keys, new_values

