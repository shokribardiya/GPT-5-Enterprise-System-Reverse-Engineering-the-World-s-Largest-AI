class GPT5Safety:
    """
    GPT-5 Safety and Alignment System.
    
    Implements the "Safe-Completions" approach described in the GPT-5 System Card:
    Instead of binary refusal, the model provides helpful responses that stay
    within safety boundaries. Combined with RLHF, DPO, and Constitutional AI
    training, this achieves output-centric safety.
    
    Key features:
    - Safe-Completions: Output-centric safety, maximizes helpfulness
    - RLHF Alignment: Trained with human preference data
    - Constitutional AI: Rule-based constraints
    - Content filtering: Detect and adjust harmful outputs
    - Bias detection: Identify and mitigate biased generations
    """
    
    def __init__(self, config: GPT5Config):
        self.config = config
        self.enabled = config.safe_completions_enabled
        
        # High-risk topic categories
        self.high_risk_categories = {
            "violence": [
                "bomb", "weapon", "kill", "attack", "terrorist", "assassin",
                "murder", "torture", "massacre", "genocide"
            ],
            "self_harm": [
                "suicide", "self-harm", "cutting", "overdose", "hang myself",
                "end my life", "want to die"
            ],
            "illegal_activities": [
                "hack", "crack", "pirate", "illegal download", "drug manufacture",
                "counterfeit", "fraud", "money laundering"
            ],
            "hate_speech": [
                "racist", "sexist", "homophobic", "xenophobic", "hate group",
                "supremacist", "discrimination"
            ],
            "sexual_content": [
                "explicit", "pornographic", "sexual violence", "child exploitation",
                "non-consensual"
            ],
            "misinformation": [
                "conspiracy theory", "fake news", "hoax", "disinformation",
                "election fraud"
            ],
        }
        
        # Safety boundary keywords (details that should not be provided)
        self.safety_boundaries = [
            "step by step", "detailed instructions", "exact formula",
            "specific amounts", "how to create", "how to manufacture",
            "where to buy", "how to obtain illegally"
        ]
        
        # Safe response templates per category
        self.safe_templates = {
            "violence": (
                "I understand you're asking about this topic, but I can't provide "
                "information that could be used to harm others. I'd be happy to "
                "discuss conflict resolution, safety measures, or related topics "
                "at a conceptual level."
            ),
            "self_harm": (
                "I'm concerned about what you're expressing. While I can't provide "
                "the information you're asking for, I want you to know that help is "
                "available. Please consider reaching out to a mental health "
                "professional or a crisis helpline in your area."
            ),
            "illegal_activities": (
                "I can't provide information about illegal activities. However, "
                "I'm happy to discuss legal alternatives, security best practices, "
                "or related topics that don't involve harmful or illegal actions."
            ),
            "hate_speech": (
                "I don't generate content that promotes discrimination or hatred "
                "against groups of people. I'd be glad to discuss diversity, "
                "inclusion, or other constructive topics instead."
            ),
            "sexual_content": (
                "I can't generate explicit sexual content. I'm designed to provide "
                "safe and appropriate responses for all users."
            ),
            "misinformation": (
                "I should clarify that I can't spread unverified or false "
                "information. I'd be happy to discuss verified facts from "
                "reliable sources on this or related topics."
            ),
        }
    
    def classify_risk(self, text: str) -> Tuple[str, float]:
        """
        Classify the risk level of input text.
        
        Returns:
            category: Highest-risk category detected
            risk_score: Risk score (0.0 = safe, 1.0 = high risk)
        """
        text_lower = text.lower()
        max_score = 0.0
        max_category = "safe"
        
        for category, keywords in self.high_risk_categories.items():
            matches = sum(1 for kw in keywords if kw in text_lower)
            if matches > 0:
                score = min(matches / 3.0, 1.0)  # Normalize
                if score > max_score:
                    max_score = score
                    max_category = category
        
        return max_category, max_score
    
    def assess_response(self, prompt: str, response: str) -> Tuple[bool, str]:
        """
        Assess whether a response is safe and adjust if needed.
        
        Returns:
            is_safe: Whether the original response is safe
            final_response: Safe version of the response
        """
        if not self.enabled:
            return True, response
        
        # Classify prompt risk
        category, risk_score = self.classify_risk(prompt)
        
        if risk_score < self.config.safety_threshold:
            return True, response
        
        # Check if response contains boundary-crossing details
        response_lower = response.lower()
        crosses_boundary = any(boundary in response_lower for boundary in self.safety_boundaries)
        
        if crosses_boundary or risk_score > 0.9:
            # Provide safe completion instead
            safe_response = self.safe_templates.get(
                category,
                "I understand your interest in this topic, but I need to provide "
                "a response that stays within safety guidelines. I'm happy to "
                "discuss related aspects at an appropriate level."
            )
            return False, safe_response
        
        return True, response
    
    def apply_safety_filter(self, generated_ids: List[int], tokenizer) -> List[int]:
        """
        Apply safety filtering to generated token sequences.
        
        Checks generated content against safety policies and truncates
        or replaces unsafe segments.
        """
        # Decode to check content
        text = tokenizer.decode(generated_ids, skip_special_tokens=True)
        
        category, risk = self.classify_risk(text)
        
        if risk > 0.95:
            # Generate safe fallback
            safe_text = self.safe_templates.get(category, "I can't provide that information.")
            return tokenizer.encode(safe_text)
        
        return generated_ids

