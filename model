# MODULE 7: SwiGLU FEED-FORWARD NETWORK
# ═══════════════════════════════════════════════════════════════════════════════

class SwiGLUFFN:
    """
    SwiGLU (SiLU-Gated Linear Unit) Feed-Forward Network.
    
    GPT-5 uses SwiGLU instead of standard ReLU/GELU FFNs:
        SwiGLU(x) = (SiLU(x @ W_gate) ⊙ (x @ W_up)) @ W_down
    
    SwiGLU provides better gradient flow and has been shown to outperform
    standard activations in large language models (Shazeer, 2020; PaLM).
    
    SiLU(x) = x * σ(x) where σ is the sigmoid function.
    """
    
    def __init__(self, hidden_size: int, intermediate_size: int):
        scale_gate = math.sqrt(2.0 / hidden_size)
        scale_down = math.sqrt(2.0 / intermediate_size)
        cm = CoreMath
        
        self.W_gate = cm.random_matrix(hidden_size, intermediate_size, scale_gate)
        self.W_up = cm.random_matrix(hidden_size, intermediate_size, scale_gate)
        self.W_down = cm.random_matrix(intermediate_size, hidden_size, scale_down)
    
    def forward(self, x: List[float]) -> List[float]:
        """Apply SwiGLU transformation."""
        cm = CoreMath
        
        # Gate and up projections
        gate = cm.matvec_mul(self.W_gate, x)
        up = cm.matvec_mul(self.W_up, x)
        
        # Element-wise SiLU(gate) * up
        gated = [cm.silu(g) * u for g, u in zip(gate, up)]
        
        # Down projection
        return cm.matvec_mul(self.W_down, gated)

