        self.kv_head_dim = hidden_size // num_kv_heads
        self.heads_per_kv = num_attention_heads // num_kv_heads

    def total_parameters(self) -> int:
        """Estimate total parameter count."""
        d = self.hidden_size
        V = self.vocab_size
        L = self.num_layers
        n_heads = self.num_attention_heads
        n_kv = self.num_kv_heads
        n_exp = self.num_experts
        ffn_exp = self.expert_ffn_size
        
        # Embedding
        params = V * d  # Token embedding
        
        # Per layer:
        # Q projection: d * n_heads * head_dim
        # K projection: d * n_kv * kv_head_dim  
        # V projection: d * n_kv * kv_head_dim
        # Output: n_heads * head_dim * d
        qkv_out = d * n_heads * self.head_dim + 2 * d * n_kv * self.kv_head_dim + n_heads * self.head_dim * d
        
        # MoE: each expert has 2 FFN matrices (gate+up, down)
        # With SwiGLU: 3 matrices per expert (gate, up, down)
        moe_per_expert = 3 * d * ffn_exp
        moe_total = n_exp * moe_per_expert
        
        # Router: small network for expert selection
        router_params = d * self.router_hidden_size + self.router_hidden_size * n_exp
        
        # RMSNorm: 2 * d per layer (attention norm + FFN norm)
        norm_params = 2 * d
        
        params += L * (qkv_out + moe_total + router_params + norm_params)
        
        # LM head (tied with embedding)
        # params += V * d  # Already counted if tied
        
        # Final norm
        params += d
        
        return params

