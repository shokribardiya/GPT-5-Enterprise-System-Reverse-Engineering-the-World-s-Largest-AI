class CoreMath:
    """Pure Python mathematical operations optimized for neural networks."""
    
    @staticmethod
    def matmul_2d(A: List[List[float]], B: List[List[float]]) -> List[List[float]]:
        """Optimized 2D matrix multiplication C = A @ B."""
        m, k = len(A), len(A[0])
        k2, n = len(B), len(B[0])
        assert k == k2, f"Shape mismatch: ({m},{k}) @ ({k2},{n})"
        # Transpose B for cache-friendly access
        B_T = [[B[i][j] for i in range(k)] for j in range(n)]
        C = [[0.0] * n for _ in range(m)]
        for i in range(m):
            Ai = A[i]
            Ci = C[i]
            for j in range(n):
                Bj = B_T[j]
                s = 0.0
                for p in range(k):
                    s += Ai[p] * Bj[p]
                Ci[j] = s
        return C

    @staticmethod
    def matvec_mul(A: List[List[float]], x: List[float]) -> List[float]:
        """Matrix-vector multiplication y = A @ x."""
        m, n = len(A), len(A[0])
        assert len(x) == n, f"Shape mismatch: ({m},{n}) @ ({len(x)},)"
        return [sum(A[i][j] * x[j] for j in range(n)) for i in range(m)]

    @staticmethod
    def transpose_2d(A: List[List[float]]) -> List[List[float]]:
        """Transpose a 2D list."""
        if not A:
            return []
        return [[A[i][j] for i in range(len(A))] for j in range(len(A[0]))]

    @staticmethod
    def add_2d(A: List[List[float]], B: List[List[float]]) -> List[List[float]]:
        """Element-wise addition of 2D lists."""
        return [[A[i][j] + B[i][j] for j in range(len(A[0]))] for i in range(len(A))]

    @staticmethod
    def softmax(x: List[float]) -> List[float]:
        """Numerically stable softmax."""
        max_x = max(x)
        exps = [math.exp(xi - max_x) for xi in x]
        total = sum(exps)
        return [e / total for e in exps]

    @staticmethod
    def silu(x: float) -> float:
        """SiLU (Swish) activation: x * sigmoid(x)."""
        return x / (1.0 + math.exp(-x))

    @staticmethod
    def gelu(x: float) -> float:
        """GELU activation (tanh approximation)."""
        return 0.5 * x * (1.0 + math.tanh(math.sqrt(2.0 / math.pi) * (x + 0.044715 * x**3)))

    @staticmethod
    def layer_norm(x: List[float], gamma: List[float], beta: List[float], eps: float = 1e-6) -> List[float]:
        """Layer normalization."""
        n = len(x)
        mean = sum(x) / n
        var = sum((xi - mean) ** 2 for xi in x) / n
        inv_std = 1.0 / math.sqrt(var + eps)
        return [gamma[i] * (x[i] - mean) * inv_std + beta[i] for i in range(n)]

    @staticmethod
    def rms_norm(x: List[float], weight: List[float], eps: float = 1e-6) -> List[float]:
        """Root Mean Square normalization."""
        n = len(x)
        ms = sum(xi * xi for xi in x) / n
        rms = 1.0 / math.sqrt(ms + eps)
        return [xi * rms * weight[i] for i, xi in enumerate(x)]

    @staticmethod
    def random_matrix(rows: int, cols: int, scale: float = 1.0) -> List[List[float]]:
        """Initialize matrix with scaled normal distribution."""
        return [[random.gauss(0, scale) for _ in range(cols)] for _ in range(rows)]

    @staticmethod
    def random_vector(size: int, scale: float = 1.0) -> List[float]:
        """Initialize vector with scaled normal distribution."""
        return [random.gauss(0, scale) for _ in range(size)]

    @staticmethod
    def top_k_filter(logits: List[float], k: int) -> List[float]:
        """Zero out logits below top-k."""
        if k <= 0 or k >= len(logits):
            return logits
        threshold = sorted(logits, reverse=True)[k]
        return [l if l >= threshold else float('-inf') for l in logits]

    @staticmethod
    def top_p_filter(logits: List[float], p: float) -> List[float]:
        """Nucleus sampling filter."""
        sorted_indices = sorted(range(len(logits)), key=lambda i: logits[i], reverse=True)
        sorted_logits = [logits[i] for i in sorted_indices]
        probs = CoreMath.softmax(sorted_logits)
        cumsum = 0.0
        cutoff_idx = len(logits)
        for i, prob in enumerate(probs):
            cumsum += prob
            if cumsum > p:
                cutoff_idx = i + 1
                break
        filtered = [float('-inf')] * len(logits)
        for i in range(cutoff_idx):
            filtered[sorted_indices[i]] = logits[sorted_indices[i]]
        return filtered

